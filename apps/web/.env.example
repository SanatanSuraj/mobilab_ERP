# Instigenie ERP — apps/web dev environment
# Copy to .env.local for local overrides.
#
# None of these are secrets — they are base URLs / public config.
# NEXT_PUBLIC_* values are baked into the client bundle at build time.

# ─────────────────────────────────────────────────────────────────
# API base URLs
# ─────────────────────────────────────────────────────────────────
# The internal API the web app calls.
# In dev, the API runs on port 4000 (see apps/api).
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# For any server-side fetching from Next (Route Handlers, Server Actions).
INTERNAL_API_BASE_URL=http://localhost:4000

# ─────────────────────────────────────────────────────────────────
# Observability deep-links (admin/audit page)
# ─────────────────────────────────────────────────────────────────
# The audit dashboard renders per-row deep-links to Loki (log viewer)
# and Tempo (trace viewer) keyed on trace_id (migration 19). Dev defaults
# line up with docker-compose.dev.yml; in prod point at the Grafana
# tenant serving those datasources (e.g. https://grafana.prod.internal).
NEXT_PUBLIC_LOKI_BASE_URL=http://localhost:3100/grafana
NEXT_PUBLIC_TEMPO_BASE_URL=http://localhost:3200/grafana
