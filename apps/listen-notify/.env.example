# apps/listen-notify — outbox LISTEN/NOTIFY dispatcher. Copy to .env for local dev.

# Non-superuser app role. The LISTENer and the writers need the same role
# to see the same event stream per Postgres' role-scoped NOTIFY semantics.
DATABASE_URL=postgres://mobilab_app:mobilab_dev@localhost:5434/mobilab
REDIS_BULL_URL=redis://localhost:6381

METRICS_PORT=4002
LOG_LEVEL=debug
NODE_ENV=development

OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
