# apps/listen-notify — outbox LISTEN/NOTIFY dispatcher. Copy to .env for local dev.

# Non-superuser app role. The LISTENer and the writers need the same role
# to see the same event stream per Postgres' role-scoped NOTIFY semantics.
#
# IMPORTANT: this URL MUST NOT point through PgBouncer (default :6432).
# PgBouncer's transaction mode drops LISTEN subscriptions between queries,
# which silently breaks outbox dispatch. Boot-time assertDirectPgUrl()
# refuses to start if the URL looks like pgbouncer. Prefer DATABASE_DIRECT_URL
# when you have a dedicated direct-PG url; we fall back to DATABASE_URL for
# dev stacks that only have one pg endpoint.
DATABASE_DIRECT_URL=postgres://instigenie_app:instigenie_dev@localhost:5434/instigenie
DATABASE_URL=postgres://instigenie_app:instigenie_dev@localhost:5434/instigenie
REDIS_BULL_URL=redis://localhost:6381

METRICS_PORT=4002
LOG_LEVEL=debug
NODE_ENV=development

OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
