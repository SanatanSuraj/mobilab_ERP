# apps/listen-notify — outbox LISTEN/NOTIFY dispatcher. Copy to .env for
# local dev.
#
# For production: production values come from Vault (see
# docs/runbooks/secret-rotation.md).

# ─────────────────────────────────────────────────────────────────
# Database — MUST be direct-PG, NOT pgbouncer
# ─────────────────────────────────────────────────────────────────
# Non-superuser app role. The LISTENer and the writers need the same
# role to see the same event stream per Postgres' role-scoped NOTIFY
# semantics.
#
# IMPORTANT: this URL MUST NOT point through PgBouncer (default :6432).
# PgBouncer's transaction mode drops LISTEN subscriptions between
# queries, silently breaking outbox dispatch. Boot-time
# assertDirectPgUrl() refuses to start if the URL looks like pgbouncer.
# Prefer DATABASE_DIRECT_URL when you have a dedicated direct-PG url;
# we fall back to DATABASE_URL for dev stacks that only have one pg
# endpoint.
DATABASE_DIRECT_URL=postgres://instigenie_app:instigenie_dev@localhost:5434/instigenie
DATABASE_URL=postgres://instigenie_app:instigenie_dev@localhost:5434/instigenie

# Override the pgbouncer port assertDirectPgUrl watches for. Only set
# if your pgbouncer runs on a non-default port.
PGBOUNCER_PORT=6432

# ─────────────────────────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────────────────────────
REDIS_BULL_URL=redis://localhost:6381

# ─────────────────────────────────────────────────────────────────
# Runtime
# ─────────────────────────────────────────────────────────────────
# env.ts:34 reads LISTEN_NOTIFY_PORT. METRICS_PORT is a dev-compose alias.
METRICS_PORT=4002
LOG_LEVEL=debug
NODE_ENV=development

# ─────────────────────────────────────────────────────────────────
# Observability
# ─────────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
