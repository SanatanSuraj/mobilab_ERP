{
  "name": "@instigenie/listen-notify",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./drain": "./src/drain.ts"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=.env src/index.ts",
    "start": "tsx --env-file-if-exists=.env src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint src",
    "test": "vitest run"
  },
  "dependencies": {
    "@instigenie/db": "workspace:*",
    "@instigenie/errors": "workspace:*",
    "@instigenie/observability": "workspace:*",
    "@instigenie/queue": "workspace:*",
    "@instigenie/resilience": "workspace:*",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@instigenie/config": "workspace:*",
    "@types/node": "^22.9.0",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
