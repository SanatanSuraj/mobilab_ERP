{
  "name": "@instigenie/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./auth/service": "./src/modules/auth/service.ts",
    "./auth/tokens": "./src/modules/auth/tokens.ts",
    "./crm/quotations": "./src/modules/crm/quotations.service.ts",
    "./crm/sales-orders": "./src/modules/crm/sales-orders.service.ts",
    "./finance/sales-invoices": "./src/modules/finance/sales-invoices.service.ts",
    "./inventory/reservations": "./src/modules/inventory/reservations.service.ts",
    "./inventory/stock": "./src/modules/inventory/stock.service.ts",
    "./approvals": "./src/modules/approvals/approvals.service.ts",
    "./esignature": "./src/modules/esignature/service.ts",
    "./external": "./src/modules/external/index.ts",
    "./notifications": "./src/modules/notifications/index.ts",
    "./portal": "./src/modules/portal/index.ts",
    "./qc/certs.service": "./src/modules/qc/certs.service.ts"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=.env src/index.ts",
    "start": "tsx --env-file-if-exists=.env src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint src",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/cookie": "^10.0.1",
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^12.0.1",
    "@fastify/rate-limit": "^10.1.1",
    "@fastify/sensible": "^6.0.1",
    "@instigenie/cache": "workspace:*",
    "@instigenie/contracts": "workspace:*",
    "@instigenie/db": "workspace:*",
    "@instigenie/errors": "workspace:*",
    "@instigenie/money": "workspace:*",
    "@instigenie/observability": "workspace:*",
    "@instigenie/qc": "workspace:*",
    "@instigenie/queue": "workspace:*",
    "@instigenie/quotas": "workspace:*",
    "@instigenie/resilience": "workspace:*",
    "@instigenie/vendor-admin": "workspace:*",
    "bcrypt": "^5.1.1",
    "fastify": "^5.1.0",
    "jose": "^5.9.6",
    "pg": "^8.13.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@instigenie/config": "workspace:*",
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^22.9.0",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
