{
  "name": "@mobilab/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./auth/service": "./src/modules/auth/service.ts",
    "./auth/tokens": "./src/modules/auth/tokens.ts"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint src",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/cookie": "^10.0.1",
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^12.0.1",
    "@fastify/rate-limit": "^10.1.1",
    "@fastify/sensible": "^6.0.1",
    "@mobilab/cache": "workspace:*",
    "@mobilab/contracts": "workspace:*",
    "@mobilab/db": "workspace:*",
    "@mobilab/errors": "workspace:*",
    "@mobilab/observability": "workspace:*",
    "@mobilab/queue": "workspace:*",
    "@mobilab/quotas": "workspace:*",
    "@mobilab/resilience": "workspace:*",
    "@mobilab/vendor-admin": "workspace:*",
    "bcrypt": "^5.1.1",
    "fastify": "^5.1.0",
    "jose": "^5.9.6",
    "pg": "^8.13.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@mobilab/config": "workspace:*",
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^22.9.0",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
