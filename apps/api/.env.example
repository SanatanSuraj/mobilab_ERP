# apps/api — Fastify API environment. Copy to .env for local dev.

# ─────────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://instigenie_app:instigenie_dev@localhost:5434/instigenie
VENDOR_DATABASE_URL=postgres://instigenie_vendor:instigenie_dev@localhost:5434/instigenie

# ─────────────────────────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────────────────────────
REDIS_CACHE_URL=redis://default:v79yzsvPgExQzvrfjqcq6VMUlO4jTFi1@redis-19738.c14.us-east-1-3.ec2.cloud.redislabs.com:19738
REDIS_BULL_URL=redis://default:v79yzsvPgExQzvrfjqcq6VMUlO4jTFi1@redis-19738.c14.us-east-1-3.ec2.cloud.redislabs.com:19738

# ─────────────────────────────────────────────────────────────────
# JWT
# ─────────────────────────────────────────────────────────────────
JWT_SECRET=dev-only-secret-do-not-use-in-production-xxxxxxxx
JWT_ISSUER=instigenie-api
ACCESS_TOKEN_TTL_SEC=900
REFRESH_TOKEN_TTL_SEC=1209600

# ─────────────────────────────────────────────────────────────────
# E-signature pepper
# ─────────────────────────────────────────────────────────────────
ESIGNATURE_PEPPER=

# ─────────────────────────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────────────────────────
PORT=4000
HOST=0.0.0.0
LOG_LEVEL=debug
NODE_ENV=development
WEB_ORIGIN=http://localhost:3000

# ─────────────────────────────────────────────────────────────────
# External integrations
# ─────────────────────────────────────────────────────────────────
NIC_EWB_API_KEY=
GSTN_API_KEY=
WHATSAPP_API_TOKEN=

# ─────────────────────────────────────────────────────────────────
# Observability
# ─────────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_PG_ENHANCED=false
APP_TRACE_ID_GUC=app.current_trace_id