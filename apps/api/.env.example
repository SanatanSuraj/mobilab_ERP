# apps/api — Fastify API environment. Copy to .env for local dev.
# docker-compose.dev.yml remaps ports to avoid host collisions:
#   Postgres 5434, redis-bull 6381, redis-cache 6382.
#
# For production: production values come from Vault (see
# docs/runbooks/secret-rotation.md). Paste the rendered values over the
# dev defaults below — every line has either a working dev default or an
# empty slot waiting for a real value.

# ─────────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────────
# Non-superuser app role. RLS binds to this role. `instigenie` (superuser)
# is reserved for migrations/bootstrap (ops/sql/seed/99-app-role.sql).
DATABASE_URL=postgres://instigenie_app:instigenie_dev@localhost:5434/instigenie

# BYPASSRLS role — used ONLY by /vendor-admin/* surface. Separate
# credential so a leaked tenant password cannot escalate to vendor.
# Production MUST set this explicitly (dev falls back to DATABASE_URL).
VENDOR_DATABASE_URL=postgres://instigenie_vendor:instigenie_dev@localhost:5434/instigenie

# ─────────────────────────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────────────────────────
REDIS_CACHE_URL=redis://localhost:6382
REDIS_BULL_URL=redis://localhost:6381

# ─────────────────────────────────────────────────────────────────
# JWT — rotate per environment, min 32 chars
# ─────────────────────────────────────────────────────────────────
JWT_SECRET=dev-only-secret-do-not-use-in-production-xxxxxxxx
JWT_ISSUER=instigenie-api
ACCESS_TOKEN_TTL_SEC=900
REFRESH_TOKEN_TTL_SEC=1209600

# ─────────────────────────────────────────────────────────────────
# E-signature pepper — HMAC-SHA256 key for §9.5 approvals
# ─────────────────────────────────────────────────────────────────
# Empty is accepted ONLY when NODE_ENV is development or test. Any other
# environment requires >= 32 chars; boot will fail otherwise (env.ts:51-58).
# Generate with: openssl rand -base64 48
ESIGNATURE_PEPPER=

# ─────────────────────────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────────────────────────
PORT=4000
HOST=0.0.0.0
LOG_LEVEL=debug
NODE_ENV=development
WEB_ORIGIN=http://localhost:3000

# ─────────────────────────────────────────────────────────────────
# External integrations
# ─────────────────────────────────────────────────────────────────
# Empty in dev → circuit breaker opens → request falls back to the manual
# queue per §3.4. Fill in with real vendor keys in staging/prod.
NIC_EWB_API_KEY=
GSTN_API_KEY=
WHATSAPP_API_TOKEN=

# ─────────────────────────────────────────────────────────────────
# Observability
# ─────────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# Enrich pg spans with query text (Gate 24). Keep false unless you have a
# PII scrub rule — query text in traces can leak customer data.
OTEL_PG_ENHANCED=false
# GUC name used to propagate W3C traceparent → audit.log.trace_id
# (migration 19). Change only if you renamed the GUC on the DB side.
APP_TRACE_ID_GUC=app.current_trace_id
