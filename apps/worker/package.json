{
  "name": "@instigenie/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./handlers": "./src/handlers/index.ts"
  },
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=.env src/index.ts",
    "start": "tsx --env-file-if-exists=.env src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint src",
    "test": "vitest run"
  },
  "dependencies": {
    "@instigenie/contracts": "workspace:*",
    "@instigenie/db": "workspace:*",
    "@instigenie/errors": "workspace:*",
    "@instigenie/observability": "workspace:*",
    "@instigenie/queue": "workspace:*",
    "@instigenie/resilience": "workspace:*",
    "@react-pdf/renderer": "^4.0.0",
    "bullmq": "^5.28.1",
    "pg": "^8.13.1",
    "react": "^19.2.4",
    "resend": "^4.0.0"
  },
  "devDependencies": {
    "@instigenie/config": "workspace:*",
    "@types/node": "^22.9.0",
    "@types/pg": "^8.11.10",
    "@types/react": "^19.2.14",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
