# apps/worker — BullMQ worker host. Copy to .env for local dev.

# ─────────────────────────────────────────────────────────────────
# Database + Redis
# ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://instigenie_app:instigenie_dev@localhost:5434/instigenie
REDIS_BULL_URL=redis://localhost:6381

# ─────────────────────────────────────────────────────────────────
# Worker runtime
# ─────────────────────────────────────────────────────────────────
METRICS_PORT=4001
CONCURRENCY=5
LOG_LEVEL=debug
NODE_ENV=development

# ─────────────────────────────────────────────────────────────────
# Email (Resend)
# ─────────────────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_DISABLED=true
MAIL_FROM=InstiGenie <no-reply@instigenie.local>
MAIL_REPLY_TO=

# ─────────────────────────────────────────────────────────────────
# MinIO / S3 (PDF + attachment storage)
# ─────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=instigenie
MINIO_SECRET_KEY=instigenie_dev_minio
PDF_BUCKET=instigenie-pdfs
BRAND_NAME=InstiGenie

# ─────────────────────────────────────────────────────────────────
# Observability
# ─────────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318