# apps/worker — BullMQ worker host. Copy to .env for local dev.
# Ports mirror docker-compose.dev.yml (Postgres 5434, redis-bull 6381).

# Non-superuser app role — mandatory so RLS binds on tenant tables.
DATABASE_URL=postgres://mobilab_app:mobilab_dev@localhost:5434/mobilab
REDIS_BULL_URL=redis://localhost:6381

METRICS_PORT=4001
CONCURRENCY=5
LOG_LEVEL=debug
NODE_ENV=development

OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
