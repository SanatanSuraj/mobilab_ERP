# apps/worker — BullMQ worker host. Copy to .env for local dev.
# Ports mirror docker-compose.dev.yml (Postgres 5434, redis-bull 6381).
#
# For production: production values come from Vault (see
# docs/runbooks/secret-rotation.md). Paste rendered values over the dev
# defaults below.

# ─────────────────────────────────────────────────────────────────
# Database + Redis
# ─────────────────────────────────────────────────────────────────
# Non-superuser app role so RLS binds on tenant tables.
DATABASE_URL=postgres://instigenie_app:instigenie_dev@localhost:5434/instigenie
REDIS_BULL_URL=redis://localhost:6381

# ─────────────────────────────────────────────────────────────────
# Worker runtime
# ─────────────────────────────────────────────────────────────────
# env.ts:42-44 reads WORKER_PORT + WORKER_CONCURRENCY. METRICS_PORT and
# CONCURRENCY below are dev-compose aliases; pick whichever your platform
# injects and the other will be ignored.
METRICS_PORT=4001
CONCURRENCY=5
LOG_LEVEL=debug
NODE_ENV=development

# ─────────────────────────────────────────────────────────────────
# Email (Resend)
# ─────────────────────────────────────────────────────────────────
# Leave RESEND_API_KEY empty in dev → worker auto-sets EMAIL_DISABLED=true
# (env.ts:36-38) so email jobs route to dead-letter without hitting Resend.
# In prod, fill both RESEND_API_KEY and set EMAIL_DISABLED=false.
RESEND_API_KEY=
EMAIL_DISABLED=true
MAIL_FROM=InstiGenie <no-reply@instigenie.local>
MAIL_REPLY_TO=

# ─────────────────────────────────────────────────────────────────
# MinIO / S3 (PDF + attachment storage)
# ─────────────────────────────────────────────────────────────────
# Dev defaults line up with docker-compose.dev.yml's minio container.
# Production: paste the values `mc admin user add` produced for the app.
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=instigenie
MINIO_SECRET_KEY=instigenie_dev_minio
PDF_BUCKET=instigenie-pdfs
BRAND_NAME=InstiGenie

# ─────────────────────────────────────────────────────────────────
# Observability
# ─────────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
