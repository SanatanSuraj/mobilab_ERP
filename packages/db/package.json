{
  "name": "@instigenie/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "import": "./dist/schema/index.js",
      "default": "./dist/schema/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js",
      "default": "./dist/types.js"
    },
    "./with-org": {
      "types": "./dist/with-org.d.ts",
      "import": "./dist/with-org.js",
      "default": "./dist/with-org.js"
    },
    "./outbox": {
      "types": "./dist/outbox.d.ts",
      "import": "./dist/outbox.js",
      "default": "./dist/outbox.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "lint": "eslint src",
    "migrate:status": "tsx --env-file-if-exists=.env src/migrate/cli.ts status",
    "migrate:up": "tsx --env-file-if-exists=.env src/migrate/cli.ts up"
  },
  "dependencies": {
    "@instigenie/errors": "workspace:*",
    "@instigenie/money": "workspace:*",
    "drizzle-orm": "^0.36.4",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@instigenie/config": "workspace:*",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.28.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  },
  "files": [
    "dist"
  ]
}
