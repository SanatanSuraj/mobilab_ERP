{
  "name": "@instigenie/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./types": "./src/types.ts",
    "./with-org": "./src/with-org.ts",
    "./outbox": "./src/outbox.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "lint": "eslint src",
    "migrate:generate": "drizzle-kit generate",
    "migrate:up": "drizzle-kit migrate"
  },
  "dependencies": {
    "@instigenie/errors": "workspace:*",
    "@instigenie/money": "workspace:*",
    "drizzle-orm": "^0.36.4",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@instigenie/config": "workspace:*",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.28.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
