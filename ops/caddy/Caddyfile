# Caddy reverse proxy + automatic HTTPS for the Instigenie ERP api.
#
# Single virtual host: the JSON API. The Next.js frontend is hosted
# on Vercel (apps/web/vercel.json) so Caddy doesn't proxy it here —
# Vercel handles its own TLS for the web origin.
#
# Variables come from the compose env block:
#   API_HOSTNAME   user-facing JSON API host  (default: api.localhost)
#   ACME_EMAIL     Let's Encrypt registration email (recommended)
#
# Local development:
#   - Defaults to `api.localhost`. Caddy generates a self-signed cert
#     from its built-in internal CA. Install the root once with
#     `caddy trust` (or accept the browser warning).
#
# Production:
#   - Point real DNS at the box (A or AAAA record), set API_HOSTNAME,
#     and Caddy fetches Let's Encrypt certs at boot. Port 80 + 443
#     must be reachable from the internet for the ACME HTTP-01 challenge.
#
# This file is hot-reloaded — `docker exec caddy caddy reload --config
# /etc/caddy/Caddyfile` after edits, no full restart needed.

{
	# Email for Let's Encrypt registration. Without it, ACME still works
	# but you don't get expiry notifications.
	email {$ACME_EMAIL:admin@localhost}

	# Limit access logs to errors at the global level — per-site logging
	# is enabled below.
	servers {
		trusted_proxies static private_ranges
	}
}

{$API_HOSTNAME:api.localhost} {
	encode zstd gzip

	reverse_proxy api:4000 {
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-Proto {scheme}
	}

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
	}

	log {
		output stdout
		format json
	}
}
