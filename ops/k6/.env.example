# ops/k6/.env.example — Gate 17 load-test environment.
#
# The k6 scripts in this folder read __ENV.* (k6's term for env vars).
# You can either export these to your shell before running `k6 run …`
# or pass them inline with `-e KEY=VAL`. This file is a reference; k6
# itself does not auto-load dotenv.
#
# These are NOT app runtime secrets — they are short-lived load-test
# credentials. The JWT should be minted fresh per run and expire in a
# couple of hours.

# ─────────────────────────────────────────────────────────────────
# Mandatory (Gate 17)
# ─────────────────────────────────────────────────────────────────
# Staging API ingress. Aliased as API_BASE for legacy runbook scripts.
BASE_URL=https://staging-api.instigenie.internal
# Pre-minted staging JWT valid >= 2h with roles:
#   crm:read, inventory:reserve, finance:read, pdf:trigger, audit:read
# Aliased as LOADTEST_JWT.
JWT_TOKEN=eyJhbGc...
# Staging org UUID that has the loadtest fixtures seeded.
# Aliased as LOADTEST_ORG_ID.
ORG_ID=00000000-0000-0000-0000-000000000000

# ─────────────────────────────────────────────────────────────────
# Optional fixtures — required only for the scenarios that touch them
# ─────────────────────────────────────────────────────────────────
# reserveStock + createQuotation — seeded stock item UUID.
LOADTEST_ITEM_ID=
# createQuotation — seeded account UUID.
LOADTEST_ACCOUNT_ID=
# triggerPdfRender — seeded invoice UUID.
LOADTEST_INVOICE_ID=

# ─────────────────────────────────────────────────────────────────
# Run metadata
# ─────────────────────────────────────────────────────────────────
# Opaque identifier copied into the X-Loadtest-Run header and metric tags.
# Convention: gate17-YYYYMMDDTHHMM (UTC).
RUN_ID=gate17-20260423T0900
# Set to "smoke" to run the 5-minute pre-release smoke stages instead of
# the 1-hour soak. Any other value (or unset) runs the full soak.
# STAGES_OVERRIDE=smoke
