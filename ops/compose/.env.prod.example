# Instigenie ERP — production .env (managed-services edition)
# Copy to .env in this directory, fill in values, then:
#   docker compose -f docker-compose.prod.yml --env-file .env up -d

# ─── Image tag ──────────────────────────────────────────────────────────
VERSION=v0.1.0

# ─── Managed Postgres (Neon / Supabase / Railway) ───────────────────────
# Two URLs are required:
#   DATABASE_URL          pooled URL  — used by api + worker
#   DATABASE_DIRECT_URL   direct URL  — used by listen-notify (LISTEN/NOTIFY
#                         doesn't work through PgBouncer-style poolers).
#
# On Neon: copy the "Pooled connection" + "Direct connection" strings.
# On Supabase: "Transaction pooler" port 6543 + "Direct connection" port 5432.
DATABASE_URL=postgresql://USER:PASSWORD@HOST-pooler.region.aws.neon.tech/instigenie?sslmode=require
DATABASE_DIRECT_URL=postgresql://USER:PASSWORD@HOST.region.aws.neon.tech/instigenie?sslmode=require

# ─── Managed Redis (Upstash) ────────────────────────────────────────────
# BullMQ requires maxmemory-policy=noeviction. On Upstash this means the
# "Pro" / paid tier — the free tier evicts and will silently drop jobs.
# Use two separate Upstash databases (one for BullMQ, one for cache) so
# eviction policies don't conflict.
REDIS_BULL_URL=rediss://default:TOKEN@HOST-bull.upstash.io:6379
REDIS_CACHE_URL=rediss://default:TOKEN@HOST-cache.upstash.io:6379

# ─── Auth secrets ───────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=REPLACE_ME_32_BYTES_HEX
ESIGNATURE_PEPPER=REPLACE_ME_32_CHARS_MIN
JWT_ISSUER=instigenie-api
ACCESS_TOKEN_TTL_SEC=900

# ─── Public URLs ────────────────────────────────────────────────────────
# API_PUBLIC_URL: the api hostname Caddy fronts (this box).
# WEB_PUBLIC_URL: the Vercel deployment URL — used as the api's CORS
#                 allow-list. Set to your custom domain on Vercel, or
#                 the *.vercel.app preview URL during early deploys.
API_PUBLIC_URL=https://api.your-domain.com
WEB_PUBLIC_URL=https://app.your-domain.com

# ─── Caddy / TLS (api only — web is on Vercel with its own TLS) ─────────
API_HOSTNAME=api.your-domain.com
ACME_EMAIL=admin@your-domain.com

# ─── Email (pick one) ───────────────────────────────────────────────────
# Resend (simplest):
RESEND_API_KEY=
MAIL_FROM=InstiGenie <noreply@your-domain.com>
MAIL_REPLY_TO=
EMAIL_DISABLED=false
# Or SMTP — uncomment and fill instead of RESEND_API_KEY:
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASSWORD=

# ─── Tuning (1GB host) ──────────────────────────────────────────────────
LOG_LEVEL=info
WORKER_CONCURRENCY=2

# Upstash and most managed Redis providers disable the CONFIG command,
# which the noeviction guard uses to verify maxmemory-policy. Set this
# to 1 ONLY after verifying noeviction in the provider's UI — otherwise
# BullMQ jobs may be silently evicted under memory pressure.
BULL_REDIS_SKIP_NOEVICTION_CHECK=1

# ─── Port bindings ──────────────────────────────────────────────────────
# Default: api binds to localhost so only Caddy serves the public internet.
# API_BIND=127.0.0.1
# API_PORT=4000
# CADDY_HTTP_PORT=80
# CADDY_HTTPS_PORT=443
